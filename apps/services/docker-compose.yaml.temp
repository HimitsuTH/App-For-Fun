version: '3.9'

services:
#  node-server:
#     build: .
#     container_name: node
#     ports:
#       - "8000:8000"
  db:
    container_name: db
    image: mysql:8.1
    # command: --default-authentication-plugin=mysql_native_password
    # restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root # กำหนด user ของ root mysql
      MYSQL_DATABASE: tutorial # กำหนด database เริ่มต้นของ mysql
      MYSQL_USER: user
      MYSQL_PASSWORD: password
    ports:
      - "3306:3306"
    volumes:
        - mysql_data:/var/lib/mysql
  redis:
    image: redis:latest
    container_name: redis-container
    ports:
      - "6379:6379"

volumes:
  mysql_data: # กำหนดชื่อ volume ที่ต้องการจะสร้าง
    driver: local



