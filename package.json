{
  "name": "expenses",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "mg:up": "npx sequelize-cli db:migrate",
    "mg:down": "npx sequelize-cli db:migrate:undo",
    "mg:gen": "npx sequelize-cli migration:generate --name ",
    "dev": "turbo run dev",
    "dev:test": "turbo run dev --parallel --filter=web... --filter=services...",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@types/ioredis": "^5.0.0"
  }
}
