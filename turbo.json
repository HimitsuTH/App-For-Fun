{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false
    },
    "start": {
      "cache": true
    },
    "docker": {
      "dependsOn": ["build"],
      "outputs": ["dist/**", ".next/**"]
    }
  },
  "ui": "stream"
}
